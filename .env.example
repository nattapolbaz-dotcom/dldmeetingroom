# ── Server ─────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────
# Local
MONGO_URI=mongodb://127.0.0.1:27017/dld_meetingroom
# Atlas (production)
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/dld_meetingroom?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_EXPIRE=7d

# ── CORS ─────────────────────────────────────────────
# Comma-separated allowed origins (leave * for dev)
CLIENT_ORIGIN=*
